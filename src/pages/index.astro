---
import BaseHead from '../layouts/BaseHead.astro';
import Nav from '../components/Nav.astro';

// Tools (all the financial calculators)
const tools = [
  { emoji: "🔥", name: "FIRE Calculator", slug: "/fire-calculator", desc: "Calculate your FIRE number based on expenses and savings rate" },
  { emoji: "📊", name: "Compound Interest Calculator", slug: "/compound-interest-calculator", desc: "Calculate compound growth with monthly contributions and charts" },
  { emoji: "🏠", name: "Rental Yield Calculator", slug: "/rental-yield-calculator", desc: "Gross and net rental yield, cap rate, cash-on-cash return" },
  { emoji: "🏠", name: "Mortgage Calculator", slug: "/mortgage-calculator", desc: "Monthly payments, amortization schedule, extra payment scenarios" },
  { emoji: "📊", name: "Loan Amortization Calculator", slug: "/loan-amortization", desc: "Full amortization schedules with principal vs interest breakdown" },
  { emoji: "🛡️", name: "Emergency Fund Calculator", slug: "/emergency-fund", desc: "Ideal emergency fund based on expenses and job stability" },
  { emoji: "🏛️", name: "Tax Bracket Calculator", slug: "/tax-bracket", desc: "Effective and marginal tax rates with filing status options" },
  { emoji: "🎯", name: "Savings Goal Calculator", slug: "/savings-goal", desc: "Time to reach goals with contributions and interest factors" },
  { emoji: "💰", name: "Dividend Reinvestment Calculator", slug: "/dividend-calculator", desc: "DRIP growth projection with compound dividend chart" },
  { emoji: "📊", name: "Dollar Cost Averaging Calculator", slug: "/dca-calculator", desc: "DCA vs lump sum simulation with historical returns" },
  { emoji: "⏳", name: "Present Value Calculator", slug: "/present-value", desc: "Present value of future cash flows and annuities" },
  { emoji: "📈", name: "ROI Calculator", slug: "/roi-calculator", desc: "Return on investment with annualized returns and CAGR" },
  { emoji: "⚖️", name: "Break-Even Calculator", slug: "/break-even", desc: "Break-even in units and revenue with visual charts" },
  { emoji: "💼", name: "Salary to Hourly Converter", slug: "/salary-hourly", desc: "Annual to hourly conversion with hours and PTO factors" },
  { emoji: "💻", name: "Freelance Rate Calculator", slug: "/freelance-rate", desc: "Ideal hourly rate based on desired salary and expenses" },
  { emoji: "📈", name: "Capital Gains Tax Calculator", slug: "/capital-gains", desc: "Capital gains tax on stocks, crypto, real estate investments" },
  { emoji: "📉", name: "Inflation Calculator", slug: "/inflation-calculator", desc: "Purchasing power over time with CPI-adjusted values" },
  { emoji: "📊", name: "Profit Margin Calculator", slug: "/profit-margin", desc: "Gross, operating, net margins with markup percentage" },
  { emoji: "🧾", name: "Sales Tax Calculator", slug: "/sales-tax", desc: "Sales tax for US states and Canadian provinces" },
  { emoji: "📈", name: "Stock Return Calculator", slug: "/stock-return", desc: "Total return including dividends and holding period" },
  { emoji: "🔢", name: "Rule of 72 Calculator", slug: "/rule-of-72", desc: "Investment doubling time at given return rates" },
  { emoji: "🏖️", name: "Retirement Withdrawal Calculator", slug: "/withdrawal-calculator", desc: "Safe withdrawal rates with 4% rule and inflation" },
  { emoji: "💵", name: "Paycheck Calculator", slug: "/paycheck-calculator", desc: "Net paycheck after federal tax, state tax, and deductions" },
  { emoji: "🏡", name: "Rent vs Buy Calculator", slug: "/rent-vs-buy", desc: "Compare renting vs buying with appreciation and costs" },
  { emoji: "💳", name: "Credit Card Payoff Calculator", slug: "/credit-card-payoff", desc: "Time to pay off debt with minimum vs fixed payments" },
  { emoji: "❄️", name: "Debt Payoff Calculator", slug: "/debt-payoff", desc: "Compare snowball vs avalanche debt strategies" },
  { emoji: "🚗", name: "Lease vs Buy Calculator", slug: "/lease-buy", desc: "Compare car leasing vs buying with total cost analysis" },
  { emoji: "💰", name: "Net Income Calculator", slug: "/net-income", desc: "Take-home pay after taxes and deductions" },
  { emoji: "📊", name: "Net Worth Tracker", slug: "/net-worth-tracker", desc: "Track and visualize your net worth over time" },
  { emoji: "🍽️", name: "Tip Calculator", slug: "/tip-calculator", desc: "Calculate tips and split bills between people" },
  { emoji: "🏦", name: "401k & RRSP Calculator", slug: "/401k-calculator", desc: "Retirement savings growth with employer matches" },
  { emoji: "📉", name: "Expense Ratio Calculator", slug: "/expense-ratio", desc: "Impact of fund expense ratios on investment returns" },
  { emoji: "🏛️", name: "Bond Yield Calculator", slug: "/bond-yield", desc: "Yield to maturity, current yield, and yield to call" }
];

// Studies 
const studies = [
  { emoji: "🏢", name: "Real Estate Cap Rates by City 2026", title: "Real Estate Cap Rates by City 2026", subtitle: "50 items analyzed", slug: "/cap-rates", desc: "Comprehensive analysis of cap rates, average rents, and median prices across 50 major US cities. Find the best markets for cash-flow investing.", stat: "7.82%", statLabel: "highest cap rate", tag: "ORIGINAL RESEARCH" },
  { emoji: "🌍", name: "Income Tax Brackets by Country 2026", slug: "/tax-brackets-comparison", desc: "Comprehensive analysis of top marginal rates, effective taxes, and brackets across 46 major global economies.", stat: "46", statLabel: "countries analyzed" },
  { emoji: "💰", name: "High-Yield Savings Account Rates 2026", slug: "/savings-rate-comparison", desc: "37 accounts compared with APY, minimums, fees, and features", stat: "5.0%", statLabel: "top APY available" }
];

// Guides
const guides = [
  { emoji: "📚", name: "FIRE Movement Beginner's Guide", slug: "/guide-fire-basics", desc: "What is FIRE? Lean, Fat, Barista FIRE explained with steps" },
  { emoji: "📚", name: "Index Fund Investing 101", slug: "/guide-index-funds", desc: "Complete guide to index fund investing with tax strategies" },
  { emoji: "📚", name: "Tax Optimization Strategies", slug: "/guide-tax-optimization", desc: "Legal tax reduction: Roth conversions, HSA, tax-loss harvesting" },
  { emoji: "📚", name: "Real Estate Investing Guide", slug: "/guide-real-estate", desc: "REITs, rental properties, house hacking, BRRRR method" },
  { emoji: "📚", name: "Budgeting Methods Compared", slug: "/guide-budgeting", desc: "50/30/20, envelope, zero-based budgeting comparison" }
];

// Lists
const lists = [
  { emoji: "💰", name: "Best Budgeting Apps", slug: "/list-budgeting-apps", desc: "Compare budgeting apps by features, pricing, and bank sync" },
  { emoji: "📋", name: "Best Online Brokerages", slug: "/list-brokerages", desc: "Fidelity, Schwab, Vanguard, IBKR comparison" },
  { emoji: "💳", name: "Best No-Fee Credit Cards", slug: "/list-credit-cards", desc: "Cashback and travel rewards cards without annual fees" },
  { emoji: "🏦", name: "Best High-Yield Savings Accounts", slug: "/list-savings-accounts", desc: "Compare rates, minimums, and FDIC insurance" }
];
---
<html lang="en">
<head>
  <BaseHead />
  <title>firemaths.info — Financial Independence Tools</title>
  <meta name="description" content="Free financial calculators for FIRE, compound interest, rental yield, debt payoff strategies, and real estate investing. No signup required." />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { 
      font-family: 'Inter', -apple-system, sans-serif; 
      background: #060a12; 
      color: #c8d0de; 
      line-height: 1.6;
    }

    /* Hero */
    .hero { 
      text-align: center; 
      padding: 100px 24px 70px; 
      background: linear-gradient(180deg, #1a0f00 0%, #060a12 100%); 
      position: relative; 
    }
    .hero::before { 
      content: ''; 
      position: absolute; 
      inset: 0; 
      background: radial-gradient(circle at 50% 40%, rgba(212,160,23,0.08) 0%, transparent 60%); 
    }
    .hero-content { position: relative; z-index: 1; }
    .hero .tagline { 
      color: #D4A017; 
      font-size: 0.85rem; 
      font-weight: 700; 
      letter-spacing: 3px; 
      text-transform: uppercase; 
      margin-bottom: 16px; 
    }
    .hero h1 { 
      font-size: 3rem; 
      font-weight: 900; 
      letter-spacing: -1.5px; 
      margin-bottom: 20px; 
      background: linear-gradient(135deg, #fff 0%, #D4A017 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .hero p { 
      color: #5a6a80; 
      font-size: 1.05rem; 
      max-width: 520px; 
      margin: 0 auto; 
    }

    /* Sections */
    .section-container { 
      max-width: 1200px; 
      margin: 0 auto; 
      padding: 60px 24px; 
    }
    .section-header { 
      text-align: center; 
      margin-bottom: 40px; 
    }
    .section-tag { 
      display: inline-block; 
      background: rgba(212,160,23,0.1); 
      color: #D4A017; 
      font-size: 0.7rem; 
      font-weight: 800; 
      padding: 6px 16px; 
      border-radius: 20px; 
      letter-spacing: 1px; 
      margin-bottom: 12px; 
    }
    .section-title { 
      font-size: 2.2rem; 
      font-weight: 900; 
      color: #fff; 
      margin-bottom: 8px; 
      letter-spacing: -0.8px; 
    }
    .section-sub { 
      color: #5a6a80; 
      font-size: 1rem; 
    }

    /* Tools Grid */
    .tools-grid { 
      display: grid; 
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); 
      gap: 16px; 
    }
    .tool-card { 
      background: #141008; 
      border: 1px solid #2a2010; 
      border-radius: 12px; 
      padding: 20px; 
      text-decoration: none; 
      color: inherit; 
      display: block; 
      transition: all 0.2s ease; 
    }
    .tool-card:hover { 
      border-color: #D4A017; 
      transform: translateY(-2px); 
    }
    .tool-emoji { 
      font-size: 1.4rem; 
      margin-bottom: 8px; 
      display: block; 
    }
    .tool-name { 
      font-size: 0.95rem; 
      font-weight: 700; 
      color: #e0e8f0; 
      margin-bottom: 6px; 
    }
    .tool-desc { 
      font-size: 0.8rem; 
      color: #6a7a90; 
      line-height: 1.4; 
    }

    /* Studies Grid */
    .studies-grid { 
      display: grid; 
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); 
      gap: 24px; 
    }
    .study-card { 
      background: linear-gradient(135deg, #141008 0%, #1a1408 100%); 
      border: 1px solid #2a2010; 
      border-radius: 16px; 
      padding: 28px 24px; 
      text-decoration: none; 
      color: inherit; 
      display: block; 
      transition: all 0.3s ease; 
      position: relative; 
      overflow: hidden; 
    }
    .study-card::before { 
      content: ''; 
      position: absolute; 
      top: 0; 
      left: 0; 
      right: 0; 
      height: 2px; 
      background: linear-gradient(90deg, #D4A017, #E4B027); 
      opacity: 0; 
      transition: opacity 0.3s; 
    }
    .study-card:hover { 
      border-color: #D4A017; 
      transform: translateY(-3px); 
      box-shadow: 0 12px 40px rgba(212,160,23,0.15); 
    }
    .study-card:hover::before { opacity: 1; }
    
    .study-emoji { 
      font-size: 1.6rem; 
      margin-bottom: 12px; 
      display: block; 
    }
    .study-stat { 
      margin-bottom: 16px; 
    }
    .stat-number { 
      display: block; 
      font-size: 2rem; 
      font-weight: 900; 
      color: #D4A017; 
      line-height: 1; 
      letter-spacing: -1px; 
    }
    .stat-label { 
      display: block; 
      font-size: 0.75rem; 
      color: #5a6a80; 
      margin-top: 4px; 
    }
    .study-name { 
      font-size: 1rem; 
      font-weight: 800; 
      color: #e0e8f0; 
      margin-bottom: 8px; 
      line-height: 1.3; 
    }
    .study-desc { 
      font-size: 0.85rem; 
      color: #6a7a90; 
      line-height: 1.4; 
    }

    /* Guides & Lists Grid */
    .guides-grid, .lists-grid { 
      display: grid; 
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); 
      gap: 20px; 
    }
    .guide-card, .list-card { 
      background: #141008; 
      border: 1px solid #2a2010; 
      border-radius: 14px; 
      padding: 24px 20px; 
      text-decoration: none; 
      color: inherit; 
      display: block; 
      transition: all 0.2s ease; 
    }
    .guide-card:hover, .list-card:hover { 
      border-color: #D4A017; 
      transform: translateY(-2px); 
    }
    .guide-emoji, .list-emoji { 
      font-size: 1.5rem; 
      margin-bottom: 10px; 
      display: block; 
    }
    .guide-name, .list-name { 
      font-size: 1rem; 
      font-weight: 700; 
      color: #e0e8f0; 
      margin-bottom: 6px; 
    }
    .guide-desc, .list-desc { 
      font-size: 0.85rem; 
      color: #6a7a90; 
      line-height: 1.4; 
    }

    /* Footer */
    .footer { 
      text-align: center; 
      padding: 50px 24px; 
      font-size: 0.85rem; 
      color: #3a4a5a; 
      border-top: 1px solid #151f2e; 
      background: #040810; 
    }
    .footer a { 
      color: #D4A017; 
      text-decoration: none; 
    }
    .footer a:hover { 
      text-decoration: underline; 
    }

    /* Responsive */
    @media (max-width: 768px) {
      .hero h1 { font-size: 2.2rem; }
      .hero { padding: 70px 20px 50px; }
      .section-container { padding: 40px 20px; }
      .tools-grid, .studies-grid, .guides-grid, .lists-grid { 
        grid-template-columns: 1fr; 
      }
    }
  </style>
</head>
<body>
  <Nav />
  <!-- Hero -->
  <div class="hero">
    <div class="hero-content">
      <div class="tagline">Financial Independence Tools</div>
      <h1>firemaths.info</h1>
      <p>Run the numbers. Retire early. Free financial research & calculators.</p>
    </div>
  </div>

  <!-- Tools Section -->
  {tools.length > 0 && (
    <div class="section-container">
      <div class="section-header">
        <span class="section-tag">🛠️ TOOLS</span>
        <h2 class="section-title">Financial Calculators</h2>
        <p class="section-sub">Free, runs in your browser, no signup.</p>
      </div>
      <div class="tools-grid">
        {tools.map(tool => (
          <a class="tool-card" href={tool.slug}>
            <span class="tool-emoji">{tool.emoji}</span>
            <h3 class="tool-name">{tool.name}</h3>
            <p class="tool-desc">{tool.desc}</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Studies Section -->
  {studies.length > 0 && (
    <div class="section-container">
      <div class="section-header">
        <span class="section-tag">🔬 RESEARCH</span>
        <h2 class="section-title">Featured Studies</h2>
        <p class="section-sub">Real rate data. Scraped, compared, updated.</p>
      </div>
      <div class="studies-grid">
        {studies.map(study => (
          <a class="study-card" href={study.slug}>
            <span class="study-emoji">{study.emoji}</span>
            <div class="study-stat">
              <span class="stat-number">{study.stat}</span>
              <span class="stat-label">{study.statLabel}</span>
            </div>
            <h3 class="study-name">{study.name}</h3>
            <p class="study-desc">{study.desc}</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Guides Section -->
  {guides.length > 0 && (
    <div class="section-container">
      <div class="section-header">
        <span class="section-tag">📚 GUIDES</span>
        <h2 class="section-title">Financial Guides</h2>
        <p class="section-sub">Comprehensive guides for financial independence.</p>
      </div>
      <div class="guides-grid">
        {guides.map(guide => (
          <a class="guide-card" href={guide.slug}>
            <span class="guide-emoji">{guide.emoji}</span>
            <h3 class="guide-name">{guide.name}</h3>
            <p class="guide-desc">{guide.desc}</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Lists Section -->
  {lists.length > 0 && (
    <div class="section-container">
      <div class="section-header">
        <span class="section-tag">📋 LISTS</span>
        <h2 class="section-title">Curated Lists</h2>
        <p class="section-sub">Best financial tools, apps, and services compared.</p>
      </div>
      <div class="lists-grid">
        {lists.map(list => (
          <a class="list-card" href={list.slug}>
            <span class="list-emoji">{list.emoji}</span>
            <h3 class="list-name">{list.name}</h3>
            <p class="list-desc">{list.desc}</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Footer -->
  <div class="footer">
    © 2026 <a href="/">firemaths.info</a> · A <a href="https://gab.ae">GAB Ventures</a> property
  </div>
</body>
</html>