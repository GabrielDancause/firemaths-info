---
import BaseHead from '../layouts/BaseHead.astro';

const studies = [
  {
    title: "High-Yield Savings Account Rates 2026",
    subtitle: "37 Accounts Compared",
    slug: "/savings-rate-comparison",
    stat: "5.0%",
    statLabel: "top APY available",
    desc: "We compared 37 high-yield savings accounts from neobanks and online banks. APY, minimum deposits, fees, and features side by side.",
    tag: "ORIGINAL RESEARCH",
  },
];

const tools = [
  { emoji: "🔥", name: "FIRE Calculator", desc: "How much do you need to retire early? Calculate your FIRE number based on expenses, savings rate, and investment returns.", slug: "/fire-calculator" },
  { emoji: "📊", name: "Compound Interest", desc: "Calculate compound interest with monthly contributions. Visual chart showing growth over 5-40 years. Compare scenarios side by side.", slug: "/compound-interest-calculator" },
  { emoji: "🏠", name: "Rental Yield Calculator", desc: "Is that property worth it? Calculate gross and net rental yield, cap rate, and cash-on-cash return.", slug: "/rental-yield-calculator" },
  { emoji: "🏠", name: "Mortgage Calculator", desc: "Monthly payments, total interest, amortization schedule. Fixed vs variable. Extra payment scenarios.", slug: "/mortgage-calculator" },
  { emoji: "📊", name: "Loan Amortization Calculator", desc: "Full amortization schedules. Principal vs interest breakdown. Balance chart over time.", slug: "/loan-amortization" },
  { emoji: "🛡️", name: "Emergency Fund Calculator", desc: "Ideal emergency fund based on expenses, job stability, dependents. 3/6/12 month targets.", slug: "/emergency-fund" },
  { emoji: "🏛️", name: "Tax Bracket Calculator", desc: "Effective and marginal tax rates. US federal. Single vs married filing breakdown.", slug: "/tax-bracket" },
  { emoji: "🎯", name: "Savings Goal Calculator", desc: "Time to reach savings goal with contributions. Interest and inflation factors. Progress chart.", slug: "/savings-goal" },
  { emoji: "💰", name: "Dividend Reinvestment Calculator", desc: "DRIP growth projection. Stock price, yield, holding period. Compound growth chart.", slug: "/dividend-calculator" },
  { emoji: "📊", name: "Dollar Cost Averaging Calculator", desc: "DCA vs lump sum simulation. Amount, frequency, historical returns. Average cost basis.", slug: "/dca-calculator" },
  { emoji: "⏳", name: "Present Value Calculator", desc: "Present value of future cash flows. Single amounts and annuities. Discount rate.", slug: "/present-value" },
  { emoji: "📈", name: "ROI Calculator", desc: "Return on investment with annualized returns. Multiple investments. Total return and CAGR.", slug: "/roi-calculator" },
  { emoji: "⚖️", name: "Break-Even Calculator", desc: "Break-even in units and revenue. Fixed costs, variable costs, selling price. Visual chart.", slug: "/break-even" },
  { emoji: "💼", name: "Salary to Hourly Converter", desc: "Annual, monthly, biweekly, weekly, hourly conversion. Hours and PTO factors.", slug: "/salary-hourly" },
  { emoji: "💻", name: "Freelance Rate Calculator", desc: "Ideal hourly/project rate. Desired salary, expenses, taxes, billable hours.", slug: "/freelance-rate" },
  { emoji: "📈", name: "Capital Gains Tax Calculator", desc: "Capital gains tax on stocks, crypto, real estate. Short-term vs long-term rates.", slug: "/capital-gains" },
  { emoji: "📉", name: "Inflation Calculator", desc: "Purchasing power over time. Amount and year range. CPI-adjusted values.", slug: "/inflation-calculator" },
  { emoji: "📊", name: "Profit Margin Calculator", desc: "Gross, operating, net margins. Revenue and costs. Markup percentage.", slug: "/profit-margin" },
  { emoji: "🧾", name: "Sales Tax Calculator", desc: "Sales tax for US states and Canadian provinces. Tax amount and total.", slug: "/sales-tax" },
  { emoji: "📈", name: "Stock Return Calculator", desc: "Total return including dividends. Buy/sell price, holding period, dividends.", slug: "/stock-return" },
  { emoji: "🔢", name: "Rule of 72 Calculator", desc: "Doubling time at given return rate. Rules of 72, 70, 69.3. Exact time.", slug: "/rule-of-72" },
  { emoji: "🏖️", name: "Retirement Withdrawal Calculator", desc: "Safe withdrawal rates. 4% rule. Inflation, Social Security, portfolio allocation.", slug: "/withdrawal-calculator" },
  { emoji: "💵", name: "Paycheck Calculator", desc: "Estimate net paycheck after deductions. Federal tax, state tax, benefits.", slug: "/paycheck-calculator" },
  { emoji: "🏡", name: "Rent vs Buy Calculator", desc: "Compare renting vs buying a home. Factor in appreciation, maintenance, opportunity cost.", slug: "/rent-vs-buy" },
  { emoji: "💳", name: "Credit Card Payoff Calculator", desc: "How long to pay off credit card debt. Minimum payments vs fixed payments. Interest saved.", slug: "/credit-card-payoff" },
  { emoji: "❄️", name: "Debt Payoff Calculator", desc: "Compare snowball vs avalanche strategies side by side. See which saves more interest and time.", slug: "/debt-payoff" },
  { emoji: "🚗", name: "Lease vs Buy Calculator", desc: "Compare leasing vs buying a car. Total cost, monthly payments, depreciation.", slug: "/lease-buy" },
  { emoji: "💰", name: "Net Income Calculator", desc: "Calculate take-home pay after taxes and deductions. Federal, state, FICA.", slug: "/net-income" },
  { emoji: "📊", name: "Net Worth Tracker", desc: "Track assets vs liabilities. Calculate and visualize your net worth over time.", slug: "/net-worth-tracker" },
  { emoji: "🍽️", name: "Tip Calculator", desc: "Calculate tip amount and split bills between people. Custom tip percentages.", slug: "/tip-calculator" },
  { emoji: "📚", name: "FIRE Movement: Beginner's Guide", desc: "What is FIRE? Lean, Fat, Barista FIRE explained. Steps to financial independence.", slug: "/guide-fire-basics" },
  { emoji: "📚", name: "Tax Optimization Strategies", desc: "Legal tax reduction: tax-loss harvesting, Roth conversions, HSA, 529 plans, charitable giving.", slug: "/guide-tax-optimization" },
  { emoji: "🏦", name: "401k & RRSP Calculator", slug: "/401k-calculator", desc: "Calculate your 401k or RRSP retirement savings growth. Employer matches, catch-up contributions, Traditional vs Roth." },
  { emoji: "📉", name: "Expense Ratio Calculator", slug: "/expense-ratio", desc: "Calculate the impact of fund expense ratios on your investment returns over time. Compare fees between funds." },
  { emoji: "🏛️", name: "Bond Yield Calculator", slug: "/bond-yield", desc: "Calculate yield to maturity (YTM), current yield, and yield to call (YTC) for bonds." },
  { emoji: "📚", name: "Index Fund Investing 101", slug: "/guide-index-funds", desc: "Complete guide and cheat sheet to index fund investing. Total Market, S&P 500, International funds, and tax-efficient strategies." },
  { emoji: "💰", name: "Best Budgeting Apps", desc: "Compare the best budgeting apps by features, pricing, bank sync, and ease of use.", slug: "/list-budgeting-apps" },
  { emoji: "📚", name: "Real Estate Investing for Beginners", desc: "How to start real estate investing: REITs, rental properties, house hacking, BRRRR method. Pros and cons.", slug: "/guide-real-estate" },
  { emoji: "📋", name: "Best Online Brokerages Compared", desc: "Compare brokerages: Fidelity, Schwab, Vanguard, IBKR, Robinhood. Fees, features, research tools.", slug: "/list-brokerages" },
  { emoji: "📚", name: "Budgeting Methods Compared", desc: "Compare budgeting methods: 50/30/20, envelope, zero-based, pay yourself first. Comprehensive reference guide.", slug: "/guide-budgeting" },
  { emoji: "💳", name: "Best No-Fee Credit Cards", desc: "Compare the best no-annual-fee credit cards: cashback, travel rewards, and pros/cons.", slug: "/list-credit-cards" },
  { emoji: "🏦", name: "Best High-Yield Savings Accounts", desc: "Compare the best HYSAs: rates, minimums, features, and FDIC insurance. Find the best account for your savings.", slug: "/list-savings-accounts" },
  { emoji: "🏗️", name: "BRRRR Profit Estimator", desc: "Buy, Rehab, Rent, Refinance, Repeat. Model the full cycle and see your return on investment.", soon: true },
];
---
<html lang="en">
<head>
  <BaseHead
    title="FIRE Maths — Personal Finance Calculators, FIRE Tools & Real Estate Analysis"
    description="Free financial calculators for FIRE (Financial Independence, Retire Early), compound interest, rental yield, debt payoff strategies, and real estate investing. No signup required."
    ogTitle="FIRE Maths — Run the Numbers. Retire Early."
    ogDescription="Free FIRE calculators, compound interest tools, rental yield analysis, and debt payoff comparisons."
  />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: #0c0a00; color: #e0d8c8; }
    .hero { text-align: center; padding: 100px 24px 80px; background: linear-gradient(180deg, #1a0f00 0%, #0c0a00 100%); position: relative; }
    .hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 50% 40%, rgba(184,67,11,0.08) 0%, transparent 60%); }
    .hero-content { position: relative; z-index: 1; }
    .hero h1 { font-size: 3.2rem; font-weight: 900; letter-spacing: -1.5px; margin-bottom: 12px; background: linear-gradient(135deg, #fff 0%, #D4A017 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .hero p { color: #666; font-size: 1.05rem; max-width: 480px; margin: 0 auto; }
    .grid { max-width: 900px; margin: 0 auto; padding: 0 24px 100px; display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
    .card { background: #141008; border: 2px solid #2a2010; border-radius: 16px; padding: 28px 24px; position: relative; }
    .card .emoji { font-size: 2rem; margin-bottom: 12px; display: block; }
    .card h2 { font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 6px; }
    .card p { font-size: 0.85rem; color: #888; line-height: 1.6; }
    .badge { position: absolute; top: 14px; right: 14px; background: #2a2010; color: #D4A017; font-size: 0.65rem; font-weight: 700; padding: 3px 10px; border-radius: 20px; }
    .live-badge { background: #D4A017; color: #0c0a00; font-weight: 800; }
    a.card.live { text-decoration: none; color: inherit; cursor: pointer; transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s; }
    a.card.live:hover { border-color: #D4A017; transform: translateY(-3px); box-shadow: 0 8px 30px rgba(212,160,23,0.1); }
    .arrow { color: #D4A017; font-size: 0.85rem; margin-top: 14px; display: inline-block; font-weight: 600; }
    .footer { text-align: center; padding: 40px 24px; font-size: 0.78rem; color: #333; border-top: 1px solid #1a1508; }
    .footer a { color: #D4A017; text-decoration: none; }
    .section-container { max-width: 900px; margin: 0 auto; padding: 0 24px; }
    .section-header { text-align: center; margin-bottom: 28px; padding-top: 10px; }
    .section-tag { display: inline-block; background: #2a2010; color: #D4A017; font-size: 0.7rem; font-weight: 800; padding: 4px 14px; border-radius: 20px; letter-spacing: 1px; margin-bottom: 10px; }
    .section-title { font-size: 1.8rem; font-weight: 900; color: #fff; margin-bottom: 4px; letter-spacing: -0.5px; }
    .section-sub { color: #555; font-size: 0.9rem; }
    .studies-grid { display: grid; grid-template-columns: 1fr; gap: 20px; margin-bottom: 50px; max-width: 600px; margin-left: auto; margin-right: auto; }
    .study-card { background: linear-gradient(135deg, #141008 0%, #1a1408 100%); border: 2px solid #2a2010; border-radius: 20px; padding: 32px 28px; text-decoration: none; color: inherit; display: block; transition: border-color 0.3s, transform 0.2s; position: relative; overflow: hidden; }
    .study-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, #D4A017, #E4B027); opacity: 0; transition: opacity 0.3s; }
    .study-card:hover { border-color: #D4A017; transform: translateY(-3px); }
    .study-card:hover::before { opacity: 1; }
    .study-tag-label { display: inline-block; background: rgba(212,160,23,0.12); color: #D4A017; font-size: 0.6rem; font-weight: 800; padding: 3px 10px; border-radius: 12px; letter-spacing: 0.8px; margin-bottom: 14px; }
    .study-stat { margin-bottom: 14px; }
    .stat-number { display: block; font-size: 2.4rem; font-weight: 900; color: #D4A017; line-height: 1; letter-spacing: -1px; }
    .stat-label { display: block; font-size: 0.82rem; color: #666; margin-top: 4px; }
    .study-title { font-size: 1.12rem; font-weight: 800; color: #fff; margin-bottom: 4px; }
    .study-subtitle { font-size: 0.8rem; color: #D4A017; margin-bottom: 10px; font-weight: 600; }
    .study-desc { font-size: 0.85rem; color: #777; line-height: 1.6; margin-bottom: 14px; }
    .study-cta { color: #D4A017; font-size: 0.85rem; font-weight: 700; }
    .grid { margin-bottom: 50px; }
    @media (max-width: 600px) { .hero h1 { font-size: 2.2rem; } .hero { padding: 70px 20px 50px; } .grid { grid-template-columns: 1fr; } .stat-number { font-size: 2rem; } }
  </style>
</head>
<body>
<div class="hero">
  <div class="hero-content">
    <h1>FIRE Maths 🔥</h1>
    <p>Run the numbers. Retire early. Free financial research & calculators.</p>
  </div>
</div>

<div class="section-container">
  <div class="section-header">
    <span class="section-tag">🔬 ORIGINAL RESEARCH</span>
    <h2 class="section-title">Featured Studies</h2>
    <p class="section-sub">Real rate data. Scraped, compared, updated.</p>
  </div>
  <div class="studies-grid">
    {studies.map(s => (
      <a class="study-card" href={s.slug}>
        <span class="study-tag-label">{s.tag}</span>
        <div class="study-stat">
          <span class="stat-number">{s.stat}</span>
          <span class="stat-label">{s.statLabel}</span>
        </div>
        <h3 class="study-title">{s.title}</h3>
        <p class="study-subtitle">{s.subtitle}</p>
        <p class="study-desc">{s.desc}</p>
        <span class="study-cta">Read the study →</span>
      </a>
    ))}
  </div>
</div>

<div class="section-container">
  <div class="section-header">
    <span class="section-tag">🛠️ TOOLS</span>
    <h2 class="section-title">Financial Calculators</h2>
    <p class="section-sub">Free, runs in your browser, no signup.</p>
  </div>
  <div class="grid">
    {tools.map(t => t.slug ? (
      <a class="card live" href={t.slug}>
        <span class="badge live-badge">LIVE</span>
        <span class="emoji">{t.emoji}</span>
        <h2>{t.name}</h2>
        <p>{t.desc}</p>
        <span class="arrow">Try it →</span>
      </a>
    ) : (
      <div class="card">
        {t.soon && <span class="badge">COMING SOON</span>}
        <span class="emoji">{t.emoji}</span>
        <h2>{t.name}</h2>
        <p>{t.desc}</p>
      </div>
    ))}
  </div>
</div>

<div class="footer">© 2026 <a href="https://firemaths.info">firemaths.info</a> · A <a href="https://gab.ae">GAB Ventures</a> property</div>
</body>
</html>
